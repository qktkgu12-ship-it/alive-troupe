# Firebase 웹 앱 설정값 (Firebase 콘솔 > 프로젝트 설정 > 내 앱 에서 복사)
# 아래 값들을 채운 파일을 ".env.local" 이라는 이름으로 저장하세요.
# (.env.local 은 git 에 올라가지 않습니다)

NEXT_PUBLIC_FIREBASE_API_KEY=여기에_apiKey
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=여기에_authDomain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=여기에_projectId
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=여기에_storageBucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=여기에_messagingSenderId
NEXT_PUBLIC_FIREBASE_APP_ID=여기에_appId

# 최초 관리자로 지정할 이메일 (이 계정으로 로그인하면 자동으로 관리자 권한)
NEXT_PUBLIC_ADMIN_EMAIL=qktkgu12@gmail.com
